# Copy this file to .env for local development:  cp .env.example .env
# On Render, set these as Environment Variables in the service dashboard instead
# of committing a .env file.

# Base URL of your MobiControl server, no trailing path.
MC_SERVER_URL=https://your-mobicontrol-server.com

# API Client credentials from MobiControl console > Services > API Client
# (not a user account).
MC_CLIENT_ID=your-client-id
MC_CLIENT_SECRET=your-client-secret

# Random string used to sign the session cookie.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-secret-string

# Render sets PORT automatically; only needed for local runs.
PORT=3000
