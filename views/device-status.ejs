<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Device Status with AIS Usage</title>
<link rel="stylesheet" href="/style.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.4.1/papaparse.min.js"></script>
</head>
<body>
<div class="wrap">

  <header class="top">
    <div>
      <h1>Device Status with AIS Usage</h1>
      <div class="sub">Live device status from MobiControl, joined with AIS-carrier usage from an uploaded Telecom Data Usage report.</div>
    </div>
    <div style="display:flex;gap:16px;align-items:center;">
      <a href="/menu" class="back">&larr; Menu</a>
      <span class="signed-in">Signed in as <%= username %></span>
      <a href="/logout" class="back">Sign out</a>
    </div>
  </header>

  <div class="card">
    <div class="stats" id="summary"></div>
    <div class="hint" id="loadHint">Loading live device status from MobiControl…</div>
  </div>

  <!-- Optional AIS usage upload -->
  <div class="card" id="importCard">
    <div class="drop" id="drop">
      <h2>Drop a Telecom Data Usage CSV here (optional)</h2>
      <p>Adds AIS-carrier upload/download/total per device below. The file stays in your browser, nothing is uploaded. Click to browse.</p>
      <input type="file" id="file" accept=".csv,text/csv" class="hidden">
    </div>
    <div id="importErr" class="err hidden"></div>
    <div id="importOk" class="success hidden"></div>
  </div>

  <div class="card hidden" id="tableCard">
    <div class="panelhead">
      <h2>Devices</h2>
      <span class="pill" id="devCount"></span>
    </div>
    <div class="controls" style="grid-template-columns:1fr 220px 220px;margin-bottom:16px;">
      <div>
        <label>Search device / email / group</label>
        <input type="text" id="search" placeholder="Type to filter…">
      </div>
      <div>
        <label>Connection</label>
        <div class="seg" id="connSeg">
          <button type="button" data-conn="all" class="on">All</button>
          <button type="button" data-conn="online">Online</button>
          <button type="button" data-conn="offline">Offline</button>
        </div>
      </div>
      <div>
        <label>AIS usage</label>
        <div class="seg" id="aisSeg">
          <button type="button" data-ais="all" class="on">All devices</button>
          <button type="button" data-ais="only">With AIS usage</button>
        </div>
      </div>
    </div>
    <table id="devStatusTable">
      <thead><tr>
        <th>Device</th>
        <th>Group</th>
        <th>Status</th>
        <th>Battery</th>
        <th>Carrier</th>
        <th>Signal</th>
        <th>Roaming</th>
        <th class="num bar-wifi">AIS Up</th>
        <th class="num bar-cell">AIS Down</th>
        <th class="num">AIS Total</th>
      </tr></thead>
      <tbody></tbody>
    </table>
    <div class="hint">Status/battery/carrier fields depend on what this MobiControl server actually reports per device; unavailable fields show as "—". AIS usage columns populate once a report is uploaded above and are filtered to Carrier = AIS.</div>
  </div>

</div>

<script>
const $ = id => document.getElementById(id);
function esc(s){ return String(s==null?'':s).replace(/&/g,'&amp;').replace(/</g,'&lt;'); }
const fmt = kb => {
  if (kb >= 1048576) return (kb/1048576).toFixed(2)+' GB';
  if (kb >= 1024)    return (kb/1024).toFixed(1)+' MB';
  return kb.toFixed(0)+' KB';
};

// ---------- live device status ----------
let DEVICES = [];
let connFilter = 'all';
let aisFilter = 'all';
let searchText = '';

function deviceOnline(dev){
  if (dev.connected === true) return true;
  if (dev.connected === false) return false;
  if (dev.lastSeen) {
    const t = new Date(dev.lastSeen);
    if (!isNaN(t.getTime())) return (Date.now() - t.getTime()) < 20*60*1000;
  }
  return null; // unknown -- this deployment doesn't expose a field we recognize
}
function timeAgo(iso){
  const t = new Date(iso);
  if (isNaN(t.getTime())) return '—';
  const mins = Math.round((Date.now()-t.getTime())/60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return mins+'m ago';
  const hrs = Math.round(mins/60);
  if (hrs < 24) return hrs+'h ago';
  return Math.round(hrs/24)+'d ago';
}
function statusPill(dev){
  const on = deviceOnline(dev);
  if (on === true)  return '<span class="tag" style="background:#123822;color:#36d399;">● Online</span>';
  if (on === false) return '<span class="tag">● Offline'+(dev.lastSeen?' · '+esc(timeAgo(dev.lastSeen)):'')+'</span>';
  return '<span class="muted">—</span>';
}
function batteryText(dev){
  if (dev.battery === '' || dev.battery === null || dev.battery === undefined) return '—';
  const n = Number(dev.battery);
  return isFinite(n) ? (n<=1 ? Math.round(n*100)+'%' : Math.round(n)+'%') : String(dev.battery);
}

const loadDevices = fetch('/api/device-status')
  .then(r => { if (!r.ok) throw new Error('HTTP '+r.status); return r.json(); })
  .then(data => {
    DEVICES = (data.devices||[]).filter(d => d && d.name);
    $('loadHint').classList.add('hidden');
    $('tableCard').classList.remove('hidden');
    renderSummary();
    renderTable();
  })
  .catch(err => {
    $('loadHint').textContent = 'Could not load device status from MobiControl (' + err.message + ').';
    $('loadHint').classList.add('err');
  });

// ---------- optional AIS usage CSV ----------
let AIS_BY_DEVICE = {}; // lowercased device name -> {up,down,total}
let hasUsageData = false;

function normCell(c){ return String(c==null?'':c).trim(); }
function num(v){ const n = parseFloat(String(v==null?'':v).replace(/,/g,'').trim()); return isFinite(n)?n:0; }

function findHeaderRow(rows){
  for (let i=0;i<Math.min(rows.length,25);i++){
    const row=rows[i]; let hasDevice=false, hasVolume=false;
    for (let j=0;j<row.length;j++){
      const c=normCell(row[j]).toLowerCase();
      if (/device\s*name/.test(c)) hasDevice=true;
      if (/volume/.test(c)) hasVolume=true;
    }
    if (hasDevice && hasVolume) return i;
  }
  return -1;
}
function mapColumns(headerRow){
  const cols={};
  headerRow.forEach((cell,idx)=>{
    const c=normCell(cell).toLowerCase();
    if (cols.device===undefined && /device\s*name/.test(c)) cols.device=idx;
    else if (cols.upload===undefined && /upload/.test(c)) cols.upload=idx;
    else if (cols.download===undefined && /download/.test(c)) cols.download=idx;
    else if (cols.volume===undefined && /volume/.test(c)) cols.volume=idx;
    else if (cols.carrier===undefined && /carrier/.test(c)) cols.carrier=idx;
  });
  return cols;
}

function handleFile(file){
  const err = $('importErr'), ok = $('importOk');
  err.classList.add('hidden'); err.textContent = '';
  ok.classList.add('hidden'); ok.textContent = '';
  Papa.parse(file, {
    skipEmptyLines: false,
    complete: res => {
      try { ingestAisUsage(res.data); }
      catch(e){ err.textContent = e.message; err.classList.remove('hidden'); }
    },
    error: e => { err.textContent = 'Could not read file: '+e.message; err.classList.remove('hidden'); }
  });
}

function ingestAisUsage(data){
  if(!data.length) throw new Error('The file has no rows.');
  const headerIdx = findHeaderRow(data);
  if (headerIdx===-1) throw new Error('Could not find a header row with "Device Name" and "Volume" columns.');
  const cols = mapColumns(data[headerIdx]);
  if (cols.device===undefined || cols.volume===undefined) {
    throw new Error('Missing expected column(s): device name, volume (kb).');
  }
  if (cols.carrier===undefined) {
    throw new Error('This report has no "Carrier" column, so AIS-only usage cannot be isolated.');
  }

  const byDev = {};
  let aisRowCount = 0;
  for (let i=headerIdx+1;i<data.length;i++){
    const row = data[i];
    if (!row || row.length===0) continue;
    const device = normCell(row[cols.device]);
    if (!device) continue;
    const carrier = normCell(row[cols.carrier]);
    if (!/^ais$/i.test(carrier)) continue;
    aisRowCount++;
    const key = device.toLowerCase();
    const d = byDev[key] || (byDev[key]={up:0,down:0,total:0});
    d.up += cols.upload!==undefined ? num(row[cols.upload]) : 0;
    d.down += cols.download!==undefined ? num(row[cols.download]) : 0;
    d.total += num(row[cols.volume]);
  }

  if (!aisRowCount) throw new Error('No rows with Carrier = AIS were found in this report.');

  AIS_BY_DEVICE = byDev;
  hasUsageData = true;
  $('importOk').textContent = `Loaded AIS usage for ${Object.keys(byDev).length} device(s) from ${aisRowCount} row(s).`;
  $('importOk').classList.remove('hidden');
  renderSummary();
  renderTable();
}

const drop = $('drop'), fileInput = $('file');
drop.onclick = () => fileInput.click();
['dragover','dragenter'].forEach(e=>drop.addEventListener(e,ev=>{ev.preventDefault();drop.classList.add('drag');}));
['dragleave','drop'].forEach(e=>drop.addEventListener(e,ev=>{ev.preventDefault();drop.classList.remove('drag');}));
drop.addEventListener('drop', ev => { if(ev.dataTransfer.files.length) handleFile(ev.dataTransfer.files[0]); });
fileInput.onchange = () => { if(fileInput.files.length) handleFile(fileInput.files[0]); };

// ---------- filters ----------
$('connSeg').querySelectorAll('button').forEach(b=>{
  b.onclick=()=>{ $('connSeg').querySelectorAll('button').forEach(x=>x.classList.remove('on'));
    b.classList.add('on'); connFilter=b.dataset.conn; renderTable(); };
});
$('aisSeg').querySelectorAll('button').forEach(b=>{
  b.onclick=()=>{ $('aisSeg').querySelectorAll('button').forEach(x=>x.classList.remove('on'));
    b.classList.add('on'); aisFilter=b.dataset.ais; renderTable(); };
});
$('search').addEventListener('input', ()=>{ searchText = $('search').value.trim().toLowerCase(); renderTable(); });

// ---------- render ----------
function renderSummary(){
  const total = DEVICES.length;
  const online = DEVICES.filter(d=>deviceOnline(d)===true).length;
  const offline = DEVICES.filter(d=>deviceOnline(d)===false).length;
  const aisDevices = Object.keys(AIS_BY_DEVICE).length;
  const aisTotal = Object.values(AIS_BY_DEVICE).reduce((s,v)=>s+v.total,0);
  $('summary').innerHTML = `
    <div class="stat"><div class="n">${total}</div><div class="l">devices</div></div>
    <div class="stat"><div class="n">${online}</div><div class="l">online</div></div>
    <div class="stat"><div class="n">${offline}</div><div class="l">offline</div></div>
    <div class="stat"><div class="n">${hasUsageData ? aisDevices : '—'}</div><div class="l">devices w/ AIS usage</div></div>
    <div class="stat"><div class="n">${hasUsageData ? fmt(aisTotal) : '—'}</div><div class="l">total AIS volume</div></div>`;
}

function renderTable(){
  const tb = $('devStatusTable').querySelector('tbody');
  tb.innerHTML = '';

  let rows = DEVICES.filter(d=>{
    if (connFilter!=='all'){
      const on = deviceOnline(d);
      if (connFilter==='online' && on!==true) return false;
      if (connFilter==='offline' && on!==false) return false;
    }
    const ais = AIS_BY_DEVICE[String(d.name||'').trim().toLowerCase()];
    if (aisFilter==='only' && !ais) return false;
    if (searchText){
      const hay = (d.name+' '+(d.email||'')+' '+(d.path||'')).toLowerCase();
      if (!hay.includes(searchText)) return false;
    }
    return true;
  });

  rows = rows.map(d => ({ d, ais: AIS_BY_DEVICE[String(d.name||'').trim().toLowerCase()] }))
    .sort((a,b) => (b.ais?b.ais.total:0) - (a.ais?a.ais.total:0));

  $('devCount').textContent = `${rows.length} of ${DEVICES.length} device(s)`;

  if (!rows.length){
    tb.innerHTML = '<tr><td colspan="10" class="empty">No devices match the current filter.</td></tr>';
    return;
  }

  rows.forEach(({d,ais})=>{
    const label = d.email || d.name;
    const sub = label !== d.name ? `<div class="muted" style="font-size:11px;">${esc(d.name)}</div>` : '';
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td>${esc(label)}${sub}</td>
      <td class="muted" title="${esc(d.path||'')}">${esc(d.path||'—')}</td>
      <td>${statusPill(d)}</td>
      <td>${esc(batteryText(d))}</td>
      <td>${esc(d.carrier||'—')}</td>
      <td>${esc(d.signal||'—')}</td>
      <td>${d.roaming===true||/^(yes|true)$/i.test(d.roaming||'') ? '<span class="tag">Roaming</span>' : (d.roaming===false||/^(no|false)$/i.test(d.roaming||'') ? 'No' : '—')}</td>
      <td class="num bar-wifi">${ais?fmt(ais.up):'—'}</td>
      <td class="num bar-cell">${ais?fmt(ais.down):'—'}</td>
      <td class="num">${ais?fmt(ais.total):'—'}</td>`;
    tb.appendChild(tr);
  });
}
</script>
</body>
</html>
