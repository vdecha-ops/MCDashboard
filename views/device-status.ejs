<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AIS Data Usage Report Analysis</title>
<link rel="stylesheet" href="/style.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.4.1/papaparse.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
</head>
<body>
<div class="wrap">

  <header class="top">
    <div>
      <h1>AIS Data Usage Report Analysis</h1>
      <div class="sub">Live device status from MobiControl, analyzed against an uploaded AIS Data Usage report.</div>
    </div>
    <div style="display:flex;gap:16px;align-items:center;">
      <a href="/menu" class="back">&larr; Menu</a>
      <span class="signed-in">Signed in as <%= username %></span>
      <a href="/logout" class="back">Sign out</a>
    </div>
  </header>

  <div class="card">
    <div class="stats" id="summary"></div>
    <div class="hint" id="loadHint">Loading live device status from MobiControl…</div>
  </div>

  <!-- AIS Data Usage report upload (source of data for the analyses below) -->
  <div class="card" id="importCard">
    <div class="drop" id="drop">
      <h2>Drop the AIS Data Usage report here (.xlsx or .csv)</h2>
      <p>The report (e.g. "รายละเอียดการใช้ internet.xlsx") is parsed entirely in your browser -- it is never uploaded to this server. Click to browse.</p>
      <input type="file" id="file" accept=".xlsx,.xls,.csv" class="hidden">
    </div>
    <div id="importErr" class="err hidden"></div>
    <div id="importOk" class="success hidden"></div>
  </div>

  <!-- Source report details banner (mirrors the Telecom Data Usage summary bar) -->
  <div class="card hidden" id="reportBanner">
    <div class="stats" id="reportStats"></div>
  </div>

  <div class="card hidden" id="analysisCard">
    <div class="tabs" id="tabSeg">
      <button type="button" data-tab="notais" class="on">1. Not using AIS carrier</button>
      <button type="button" data-tab="offlineusage">2. Offline with usage in report</button>
      <button type="button" data-tab="inactive">3. Inactive over N days</button>
    </div>
    <div id="tabBody"></div>
  </div>

</div>

<script>
const $ = id => document.getElementById(id);
function esc(s){ return String(s==null?'':s).replace(/&/g,'&amp;').replace(/</g,'&lt;'); }
const fmt = kb => {
  if (kb >= 1048576) return (kb/1048576).toFixed(2)+' GB';
  if (kb >= 1024)    return (kb/1024).toFixed(1)+' MB';
  return kb.toFixed(0)+' KB';
};

// ---------- live device status ----------
let DEVICES = [];

function deviceOnline(dev){
  if (dev.connected === true) return true;
  if (dev.connected === false) return false;
  if (dev.lastSeen) {
    const t = new Date(dev.lastSeen);
    if (!isNaN(t.getTime())) return (Date.now() - t.getTime()) < 20*60*1000;
  }
  return null; // unknown -- this deployment doesn't expose a field we recognize
}

const loadDevices = fetch('/api/device-status')
  .then(r => { if (!r.ok) throw new Error('HTTP '+r.status); return r.json(); })
  .then(data => {
    DEVICES = (data.devices||[]).filter(d => d && d.name);
    $('loadHint').classList.add('hidden');
    $('analysisCard').classList.remove('hidden');
    renderSummary();
    if (BILLING) renderReportBanner(); // devices arrived after a file was already dropped
    renderActiveTab();
  })
  .catch(err => {
    $('loadHint').textContent = 'Could not load device status from MobiControl (' + err.message + ').';
    $('loadHint').classList.add('err');
  });

function renderSummary(){
  const total = DEVICES.length;
  const online = DEVICES.filter(d=>deviceOnline(d)===true).length;
  const offline = DEVICES.filter(d=>deviceOnline(d)===false).length;
  const withPhone = DEVICES.filter(d=>d.phone).length;
  $('summary').innerHTML = `
    <div class="stat"><div class="n">${total}</div><div class="l">devices</div></div>
    <div class="stat"><div class="n">${online}</div><div class="l">online</div></div>
    <div class="stat"><div class="n">${offline}</div><div class="l">offline</div></div>
    <div class="stat"><div class="n">${withPhone}</div><div class="l">have a phone number on file</div></div>`;
}

// ---------- AIS Data Usage report parsing ----------
// The report is an AIS billing export: a few metadata rows (registrant,
// customer code, billing period, report date), then a header row containing
// "หมายเลขโทรศัพท์" (phone number), followed by one row per subscriber. The
// subscriber name has no header text of its own -- it's always the column
// immediately after the phone number. Total internet usage for the period
// is in the "รวมปริมาณการใช้งาน Internet" column, formatted as free text
// like "17 GB. 996 MB. 1023 KB." (any of the three units may be omitted).
let BILLING = null; // { period, reportDate, records: [...], byPhone: {...} }

function normalizePhone(p){
  const digits = String(p||'').replace(/\D/g,'');
  return digits.slice(-9); // last 9 digits -- absorbs leading 0 / +66 / 66 variants
}

function parseUsageText(s){
  s = String(s==null ? '' : s);
  const gbM = s.match(/(\d+(?:\.\d+)?)\s*GB/i);
  const mbM = s.match(/(\d+(?:\.\d+)?)\s*MB/i);
  const kbM = s.match(/(\d+(?:\.\d+)?)\s*KB/i);
  const gb = gbM ? parseFloat(gbM[1]) : 0;
  const mb = mbM ? parseFloat(mbM[1]) : 0;
  const kb = kbM ? parseFloat(kbM[1]) : 0;
  const totalKB = gb*1024*1024 + mb*1024 + kb;
  return { totalKB, hasUsage: totalKB > 0, text: s.trim() || '0 KB.' };
}

function findAisHeaderRowIndex(rows){
  for (let i=0; i<Math.min(rows.length,20); i++){
    const row = rows[i] || [];
    for (let j=0; j<row.length; j++){
      if (/หมายเลขโทรศัพท์/.test(String(row[j]==null?'':row[j]))) return i;
    }
  }
  return -1;
}

function findPeriodInfo(rows){
  let period = null, reportDate = null;
  for (let i=0; i<Math.min(rows.length,20); i++){
    const row = rows[i] || [];
    for (let j=0; j<row.length; j++){
      const c = String(row[j]==null?'':row[j]);
      if (/เดือน\s*\/\s*รอบค่าใช้บริการ/.test(c)) period = String(row[j+1]==null?'':row[j+1]).trim();
      if (/รายงานวันที่/.test(c)) reportDate = String(row[j+1]==null?'':row[j+1]).trim();
    }
  }
  return { period, reportDate };
}

// The billing period is a single "MM/YYYY" string (e.g. "06/2026") -- there's
// no per-row date range in this report, so we treat the whole calendar month
// as the reporting window when checking whether a device's last-known
// connection falls within/before it.
function periodEndDate(periodStr){
  const m = /^(\d{1,2})\/(\d{4})$/.exec(String(periodStr||'').trim());
  if (!m) return null;
  const month = parseInt(m[1],10), year = parseInt(m[2],10);
  return new Date(year, month, 0, 23, 59, 59, 999); // last instant of that month
}
function periodStartDate(periodStr){
  const m = /^(\d{1,2})\/(\d{4})$/.exec(String(periodStr||'').trim());
  if (!m) return null;
  const month = parseInt(m[1],10), year = parseInt(m[2],10);
  return new Date(year, month-1, 1, 0, 0, 0, 0);
}

function parseAisBillingReport(rows){
  const headerIdx = findAisHeaderRowIndex(rows);
  if (headerIdx === -1) {
    throw new Error('Could not find the phone-number header ("หมายเลขโทรศัพท์") in this file -- is this the AIS Data Usage report?');
  }
  const headerRow = rows[headerIdx];
  const phoneCol = headerRow.findIndex(c => /หมายเลขโทรศัพท์/.test(String(c==null?'':c)));
  const nameCol = phoneCol + 1;
  let usageCol = headerRow.findIndex(c => String(c==null?'':c).trim() === 'รวมปริมาณการใช้งาน Internet');
  if (usageCol === -1) {
    usageCol = headerRow.findIndex(c => /รวมปริมาณการใช้งาน\s*Internet/i.test(String(c==null?'':c)) && !/บาท/.test(String(c==null?'':c)));
  }
  if (usageCol === -1) {
    throw new Error('Could not find the "รวมปริมาณการใช้งาน Internet" usage column in this file.');
  }

  const { period, reportDate } = findPeriodInfo(rows);

  const records = [];
  for (let i = headerIdx+1; i < rows.length; i++){
    const row = rows[i];
    if (!row) continue;
    const phoneRaw = String(row[phoneCol]==null?'':row[phoneCol]).trim();
    if (!/^0\d{9}$/.test(phoneRaw)) continue; // skip anything that isn't a 10-digit Thai mobile number
    const name = String(row[nameCol]==null?'':row[nameCol]).trim();
    const usage = parseUsageText(row[usageCol]);
    records.push({ phone: phoneRaw, phoneKey: normalizePhone(phoneRaw), name, ...usage });
  }
  return { period, reportDate, records };
}

function handleFile(file){
  const err = $('importErr'), ok = $('importOk');
  err.classList.add('hidden'); err.textContent = '';
  ok.classList.add('hidden'); ok.textContent = '';

  const showErr = (m) => { err.textContent = m; err.classList.remove('hidden'); };
  const ingestSafe = (rows) => { try { ingestBilling(rows); } catch(e){ showErr(e.message); } };

  const isCsv = /\.csv$/i.test(file.name);
  if (isCsv) {
    Papa.parse(file, {
      skipEmptyLines: false,
      complete: res => ingestSafe(res.data),
      error: e => showErr('Could not read file: ' + e.message),
    });
  } else {
    const reader = new FileReader();
    reader.onload = (e) => {
      try {
        const wb = XLSX.read(e.target.result, { type: 'array' });
        const ws = wb.Sheets[wb.SheetNames[0]];
        const rows = XLSX.utils.sheet_to_json(ws, { header: 1, defval: '' });
        ingestSafe(rows);
      } catch (ex) { showErr('Could not read file: ' + ex.message); }
    };
    reader.onerror = () => showErr('Could not read the file.');
    reader.readAsArrayBuffer(file);
  }
}

function ingestBilling(rows){
  const parsed = parseAisBillingReport(rows);
  if (!parsed.records.length) {
    throw new Error('No subscriber rows found (expected 10-digit phone numbers starting with 0).');
  }
  const byPhone = {};
  parsed.records.forEach(r => { byPhone[r.phoneKey] = r; });
  BILLING = Object.assign({}, parsed, { byPhone });

  $('importOk').textContent = `Loaded ${parsed.records.length} subscriber row(s)` +
    (parsed.period ? ` for period ${parsed.period}` : '') + '.';
  $('importOk').classList.remove('hidden');

  renderReportBanner();
  renderActiveTab();
}

// Highlights the details of the uploaded source report as a stat bar,
// matching the Telecom Data Usage dashboard's summary-bar style.
function renderReportBanner(){
  if (!BILLING) return;
  const totalKB = BILLING.records.reduce((s,r) => s + r.totalKB, 0);
  const matchedCount = DEVICES.filter(d => d.phone && BILLING.byPhone[normalizePhone(d.phone)]).length;
  $('reportStats').innerHTML = `
    <div class="stat"><div class="n">${esc(fmt(totalKB))}</div><div class="l">total volume</div></div>
    <div class="stat"><div class="n">${BILLING.records.length}</div><div class="l">subscribers</div></div>
    <div class="stat"><div class="n">${matchedCount}</div><div class="l">matched devices</div></div>
    <div class="stat"><div class="n">${esc(BILLING.period || '—')}</div><div class="l">billing period</div></div>
    <div class="stat"><div class="n">${esc(BILLING.reportDate || '—')}</div><div class="l">report created</div></div>`;
  $('reportBanner').classList.remove('hidden');
}

const drop = $('drop'), fileInput = $('file');
drop.onclick = () => fileInput.click();
['dragover','dragenter'].forEach(e=>drop.addEventListener(e,ev=>{ev.preventDefault();drop.classList.add('drag');}));
['dragleave','drop'].forEach(e=>drop.addEventListener(e,ev=>{ev.preventDefault();drop.classList.remove('drag');}));
drop.addEventListener('drop', ev => { if(ev.dataTransfer.files.length) handleFile(ev.dataTransfer.files[0]); });
fileInput.onchange = () => { if(fileInput.files.length) handleFile(fileInput.files[0]); };

// ---------- tabs ----------
let activeTab = 'notais';
let inactiveDaysThreshold = 7;

$('tabSeg').querySelectorAll('button').forEach(b=>{
  b.onclick = () => {
    $('tabSeg').querySelectorAll('button').forEach(x=>x.classList.remove('on'));
    b.classList.add('on');
    activeTab = b.dataset.tab;
    renderActiveTab();
  };
});

function renderActiveTab(){
  if (activeTab === 'notais') renderNotAis();
  else if (activeTab === 'offlineusage') renderOfflineUsage();
  else renderInactive();
}

function tableHtml(headers, rowsArr, emptyMsg){
  if (!rowsArr.length) return `<div class="empty">${esc(emptyMsg || 'No matching devices.')}</div>`;
  const thead = '<tr>' + headers.map(h=>`<th>${esc(h)}</th>`).join('') + '</tr>';
  const tbody = rowsArr.map(cells => '<tr>' + cells.map(c=>`<td>${c}</td>`).join('') + '</tr>').join('');
  return `<div class="pill" style="margin-bottom:10px;">${rowsArr.length} device(s)</div><table><thead>${thead}</thead><tbody>${tbody}</tbody></table>`;
}

// 1) Devices whose live MobiControl carrier is not AIS.
function renderNotAis(){
  const rows = DEVICES.filter(d => !/^ais$/i.test(String(d.carrier||'').trim()));
  $('tabBody').innerHTML =
    '<div class="hint" style="margin-bottom:14px;">Based on each device\'s live CellularCarrier field from MobiControl (independent of the uploaded report).</div>' +
    tableHtml(
      ['Device / Email', 'Group', 'Carrier'],
      rows.map(d => [esc(d.email || d.name), esc(d.path || '—'), esc(d.carrier ? d.carrier : 'Unknown')]),
      'Every device with a known carrier reports AIS.'
    );
}

// 2) Devices whose last known connection to MobiControl falls within/before
// the report's own billing period (i.e. they weren't checking in around the
// time the report says they used AIS data) -- lists their email accounts,
// matched by phone number.
function renderOfflineUsage(){
  if (!BILLING) {
    $('tabBody').innerHTML = '<div class="hint">Upload the AIS Data Usage report above to run this check.</div>';
    return;
  }
  const withPhone = DEVICES.filter(d => d.phone);
  const periodEnd = periodEndDate(BILLING.period);
  const periodStart = periodStartDate(BILLING.period);

  // "Offline for this period" = never reported a last-connect time, or the
  // last one on record is on/before the end of the report's billing month
  // (i.e. no confirmed connection during or after that period).
  function offlineForPeriod(d){
    if (!d.lastSeen) return true;
    const t = new Date(d.lastSeen);
    if (isNaN(t.getTime())) return true;
    if (!periodEnd) return deviceOnline(d) === false; // couldn't parse the period -- fall back to live status
    return t.getTime() <= periodEnd.getTime();
  }

  const matches = [];
  DEVICES.forEach(d => {
    if (!d.phone) return;
    if (!offlineForPeriod(d)) return;
    const rec = BILLING.byPhone[normalizePhone(d.phone)];
    if (rec && rec.hasUsage) matches.push({ d, rec });
  });

  let html = '<div class="hint" style="margin-bottom:14px;">Devices matched by phone number to a report row with nonzero usage, whose last known MobiControl connection was on or before the end of the billing period'
    + (BILLING.period ? ' (' + esc(BILLING.period)
        + (periodStart && periodEnd ? ', ' + periodStart.toLocaleDateString() + ' – ' + periodEnd.toLocaleDateString() : '')
        + ')' : '') + '.</div>';

  if (!withPhone.length) {
    html += '<div class="empty">No device on this MobiControl server exposes a phone number field, so devices could not be matched to the report.</div>';
    $('tabBody').innerHTML = html;
    return;
  }

  if (matches.length) {
    const emails = matches.map(m => m.d.email || m.rec.name).join('\n');
    html += `<textarea readonly style="width:100%;min-height:90px;background:#0a1220;border:1px solid var(--line);border-radius:9px;color:var(--ink);padding:10px 12px;font-size:13px;margin-bottom:10px;">${esc(emails)}</textarea>`
      + '<button type="button" class="ghost" id="copyOfflineEmails" style="margin-bottom:14px;">Copy email list</button>';
  }

  html += tableHtml(
    ['Device / Email', 'Phone', 'Group', 'Last connected', 'Usage in report'],
    matches.map(({d,rec}) => [
      esc(d.email || d.name),
      esc(rec.phone),
      esc(d.path || '—'),
      d.lastSeen && !isNaN(new Date(d.lastSeen).getTime()) ? esc(new Date(d.lastSeen).toLocaleString()) : 'Never',
      esc(rec.text),
    ]),
    'No device matched a report row with usage while offline for this period.'
  );

  $('tabBody').innerHTML = html;
  const copyBtn = $('copyOfflineEmails');
  if (copyBtn) {
    copyBtn.onclick = () => {
      const emails = matches.map(m => m.d.email || m.rec.name).join('\n');
      navigator.clipboard.writeText(emails).then(() => {
        copyBtn.textContent = 'Copied!';
        setTimeout(() => { copyBtn.textContent = 'Copy email list'; }, 1500);
      }).catch(() => {});
    };
  }
}

// 3) Devices whose last-connect time (from the API) is older than a
// user-supplied number of days.
function renderInactive(){
  $('tabBody').innerHTML = `
    <div class="controls" style="grid-template-columns:200px auto 1fr;margin-bottom:16px;">
      <div>
        <label>Not connected in over (days)</label>
        <input type="number" id="inactiveDays" min="1" value="${inactiveDaysThreshold}">
      </div>
      <div style="align-self:end;">
        <button type="button" class="primary" id="applyInactive">Apply</button>
      </div>
      <div></div>
    </div>
    <div id="inactiveResults"></div>`;

  $('applyInactive').onclick = () => {
    const v = parseInt($('inactiveDays').value, 10);
    inactiveDaysThreshold = isFinite(v) && v > 0 ? v : 7;
    renderInactiveResults();
  };
  renderInactiveResults();
}

function renderInactiveResults(){
  const now = Date.now();
  const withDate = [], noDate = [];
  DEVICES.forEach(d => {
    if (!d.lastSeen) { noDate.push(d); return; }
    const t = new Date(d.lastSeen);
    if (isNaN(t.getTime())) { noDate.push(d); return; }
    const days = (now - t.getTime()) / 86400000;
    if (days > inactiveDaysThreshold) withDate.push({ d, days, t });
  });
  withDate.sort((a,b) => b.days - a.days);

  let html = tableHtml(
    ['Device / Email', 'Group', 'Last connected', 'Days since'],
    withDate.map(({d,days,t}) => [esc(d.email || d.name), esc(d.path || '—'), esc(t.toLocaleString()), Math.floor(days)]),
    `No devices have gone more than ${inactiveDaysThreshold} day(s) without connecting.`
  );
  if (noDate.length) {
    html += `<div class="hint" style="margin-top:12px;">${noDate.length} device(s) have no recorded last-connect time from this server and are not included above.</div>`;
  }
  $('inactiveResults').innerHTML = html;
}
</script>
</body>
</html>
