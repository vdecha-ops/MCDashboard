<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>MobiControl Device Groups</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="page">
    <div class="header-row">
      <div>
        <h1>Device Groups</h1>
        <p class="subtitle">Signed in as <%= username %></p>
      </div>
      <a href="/logout">Sign out</a>
    </div>

    <div class="card">
      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>

      <% if (deviceGroups && deviceGroups.length > 0) { %>
        <table>
          <thead>
            <tr>
              <th>Name</th>
              <th>Path</th>
              <th>ID</th>
              <th>Parent ID</th>
              <th>Devices</th>
            </tr>
          </thead>
          <tbody>
            <% deviceGroups.forEach(function(g) { %>
            <tr>
              <td><%= g.name %></td>
              <td><%= g.path %></td>
              <td><%= g.id %></td>
              <td><%= g.parentId %></td>
              <td><%= g.deviceCount %></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      <% } else if (!error) { %>
        <p class="empty">No device groups found.</p>
      <% } %>
    </div>
  </div>
</body>
</html>
