<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Telecom Data Usage Dashboard</title>
  <link rel="stylesheet" href="/style.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.4.1/papaparse.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
</head>
<body>
  <div class="page page-wide">
    <div class="header-row">
      <div>
        <h1>Telecom Data Usage</h1>
        <p class="sub">Upload a MobiControl usage export and explore consumption by device and app.</p>
      </div>
      <nav class="nav-links">
        <span class="signed-in">Signed in as <%= username %></span>
        <a href="/logout">Sign out</a>
      </nav>
    </div>

    <div id="uploadCard" class="card">
      <div id="dropZone" class="drop">
        <div class="drop-title">Drop your CSV here</div>
        <div class="drop-sub">or click to browse — the file is parsed in your browser, nothing is uploaded.</div>
        <input type="file" id="fileInput" accept=".csv,text/csv" hidden>
      </div>
      <p class="hint">
        Expects a MobiControl "Telecom Data Usage" report export (Device Name, Date &amp; Time, Volume (KB), Type,
        Application ID). Any junk title/summary rows above or below the real header are skipped automatically.
      </p>
      <div id="err" class="error hidden"></div>
      <div id="lookupStatus" class="hint"></div>
    </div>

    <div id="results" class="hidden">
      <div class="card summary-bar">
        <div class="stat-group"><div class="stat-value" id="statVolume">-</div><div class="stat-label">Total Volume</div></div>
        <div class="stat-group"><div class="stat-value" id="statApps">-</div><div class="stat-label">Apps</div></div>
        <div class="stat-group"><div class="stat-value" id="statDevices">-</div><div class="stat-label">Devices</div></div>
        <div class="stat-group"><div class="stat-value" id="statGroups">-</div><div class="stat-label">Groups</div></div>
        <div class="stat-group"><div class="stat-value" id="statDateRange">-</div><div class="stat-label">Date Range</div></div>
        <div class="stat-group"><div class="stat-value" id="statReportCreated">-</div><div class="stat-label">Report Created</div></div>
      </div>

      <div class="card filter-bar">
        <div class="filter-bar-row">
          <div class="filter-field">
            <label>From</label>
            <input type="date" id="fromDate">
          </div>
          <div class="filter-field">
            <label>To</label>
            <input type="date" id="toDate">
          </div>
          <div class="filter-field">
            <label>Network</label>
            <div class="segmented" id="networkSeg">
              <button type="button" class="seg-btn active" data-network="all">All</button>
              <button type="button" class="seg-btn" data-network="wifi">Wi-Fi</button>
              <button type="button" class="seg-btn" data-network="cellular">Cellular</button>
            </div>
          </div>
          <div class="filter-field">
            <label>Show Top</label>
            <select id="topNSelect">
              <option value="5">5</option>
              <option value="10" selected>10</option>
              <option value="20">20</option>
              <option value="50">50</option>
              <option value="999999">All</option>
            </select>
          </div>
          <div class="filter-field groups-field">
            <label>Groups <a href="#" id="clearGroupsLink" class="clear-inline">clear</a></label>
            <div id="groupFilterList" class="filter-list-inline">
              <p class="empty">No group data yet.</p>
            </div>
          </div>
        </div>
        <div class="filter-bar-actions">
          <button type="button" id="applyMainFilterBtn" class="apply-btn">Apply</button>
          <span class="filter-pill" id="filterPill"></span>
        </div>
      </div>

      <div class="main-col">
        <div class="card top-list-card">
          <div class="tab-nav">
            <button type="button" class="tab-btn active" data-tab="apps">Top Applications</button>
            <button type="button" class="tab-btn" data-tab="users">Top Users</button>
          </div>

          <div class="top-list-header">
            <h2 class="chart-title" id="topListTitle">Top applications by data used</h2>
            <span class="filter-pill" id="topListCount"></span>
          </div>

          <canvas id="topChart" height="260"></canvas>

          <table>
            <thead id="topListThead"></thead>
            <tbody id="topListBody"></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <script>
  (function () {
    'use strict';

    // ---- Device lookup (email + group path per device name), fetched once ----
    var deviceLookup = {}; // lowercased device name -> { name, email, path }
    var lookupReady = fetch('/api/device-lookup')
      .then(function (r) {
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.json();
      })
      .then(function (data) {
        (data.devices || []).forEach(function (d) {
          if (d && d.name) deviceLookup[d.name.trim().toLowerCase()] = d;
        });
        document.getElementById('lookupStatus').textContent =
          Object.keys(deviceLookup).length + ' device(s) loaded from MobiControl for email/group matching.';
      })
      .catch(function (err) {
        document.getElementById('lookupStatus').textContent =
          'Could not load device list from MobiControl (' + err.message + '). Devices will show without email/group.';
      });

    function lookupFor(deviceName) {
      return deviceLookup[String(deviceName || '').trim().toLowerCase()] || null;
    }

    // ---- Report parsing ----
    function normCell(c) {
      return String(c == null ? '' : c).trim();
    }

    function findHeaderRow(rows) {
      for (var i = 0; i < Math.min(rows.length, 25); i++) {
        var row = rows[i];
        var hasDeviceName = false, hasVolume = false;
        for (var j = 0; j < row.length; j++) {
          var c = normCell(row[j]).toLowerCase();
          if (/device\s*name/.test(c)) hasDeviceName = true;
          if (/volume/.test(c)) hasVolume = true;
        }
        if (hasDeviceName && hasVolume) return i;
      }
      return -1;
    }

    function mapColumns(headerRow) {
      var cols = {};
      headerRow.forEach(function (cell, idx) {
        var c = normCell(cell).toLowerCase();
        if (cols.dateTime === undefined && /date/.test(c)) cols.dateTime = idx;
        else if (cols.deviceName === undefined && /device\s*name/.test(c)) cols.deviceName = idx;
        else if (cols.upload === undefined && /upload/.test(c)) cols.upload = idx;
        else if (cols.download === undefined && /download/.test(c)) cols.download = idx;
        else if (cols.volume === undefined && /volume/.test(c)) cols.volume = idx;
        else if (cols.type === undefined && /^type$/.test(c)) cols.type = idx;
        else if (cols.roaming === undefined && /roaming/.test(c)) cols.roaming = idx;
        else if (cols.carrier === undefined && /carrier/.test(c)) cols.carrier = idx;
        else if (cols.appId === undefined && /applic/.test(c)) cols.appId = idx;
      });
      return cols;
    }

    function toNumber(v) {
      var n = parseFloat(String(v == null ? '' : v).replace(/,/g, '').trim());
      return isFinite(n) ? n : 0;
    }

    function parseDate(v) {
      var s = normCell(v);
      if (!s) return null;
      var d = new Date(s);
      return isNaN(d.getTime()) ? null : d;
    }

    // Network classification is inferred from the "Type" column. MobiControl
    // deployments vary in what values that column holds -- this matches the
    // common "Wi-Fi" / "Cellular" (or "Mobile"/"Data"/3G-5G/LTE) wording.
    // Rows whose Type doesn't match either are still counted under "All" but
    // won't match the Wi-Fi/Cellular filter buttons specifically.
    function classifyNetwork(typeVal) {
      var t = normCell(typeVal).toLowerCase();
      if (/wi-?fi/.test(t)) return 'wifi';
      if (/cell|mobile|data|3g|4g|5g|lte/.test(t)) return 'cellular';
      return 'other';
    }

    function parseReport(rawRows) {
      var headerIdx = findHeaderRow(rawRows);
      if (headerIdx === -1) {
        return { error: 'Could not find a header row with "Device Name" and "Volume" columns.' };
      }
      var cols = mapColumns(rawRows[headerIdx]);
      var rows = [];

      for (var i = headerIdx + 1; i < rawRows.length; i++) {
        var row = rawRows[i];
        if (!row || row.length === 0) continue;
        var deviceName = normCell(row[cols.deviceName]);
        if (!deviceName) continue;

        rows.push({
          deviceName: deviceName,
          date: cols.dateTime !== undefined ? parseDate(row[cols.dateTime]) : null,
          volume: toNumber(row[cols.volume]),
          upload: cols.upload !== undefined ? toNumber(row[cols.upload]) : 0,
          download: cols.download !== undefined ? toNumber(row[cols.download]) : 0,
          appId: cols.appId !== undefined ? (normCell(row[cols.appId]) || '(unknown)') : '(unknown)',
          network: cols.type !== undefined ? classifyNetwork(row[cols.type]) : 'other',
        });
      }

      return { headerIdx: headerIdx, cols: cols, rows: rows };
    }

    function fullDateRange(rows) {
      var min = null, max = null;
      rows.forEach(function (r) {
        if (!r.date) return;
        if (!min || r.date < min) min = r.date;
        if (!max || r.date > max) max = r.date;
      });
      return { min: min, max: max };
    }

    function aggregate(rows) {
      var deviceStats = {}, deviceOrder = [];
      var appStats = {}, appOrder = [];
      var totalVolume = 0, totalUpload = 0, totalDownload = 0, totalRecords = 0;

      rows.forEach(function (r) {
        totalVolume += r.volume; totalUpload += r.upload; totalDownload += r.download; totalRecords += 1;

        if (!deviceStats[r.deviceName]) { deviceStats[r.deviceName] = { volume: 0, upload: 0, download: 0, records: 0 }; deviceOrder.push(r.deviceName); }
        var ds = deviceStats[r.deviceName];
        ds.volume += r.volume; ds.upload += r.upload; ds.download += r.download; ds.records += 1;

        if (!appStats[r.appId]) { appStats[r.appId] = { volume: 0, upload: 0, download: 0, records: 0 }; appOrder.push(r.appId); }
        var as = appStats[r.appId];
        as.volume += r.volume; as.upload += r.upload; as.download += r.download; as.records += 1;
      });

      var devices = deviceOrder.map(function (name) {
        var lookup = lookupFor(name);
        return Object.assign({ name: name, email: lookup ? lookup.email : null, path: lookup ? lookup.path : '' }, deviceStats[name]);
      });
      var apps = appOrder.map(function (name) { return Object.assign({ name: name }, appStats[name]); });
      var groupCount = new Set(devices.map(function (d) { return d.path; }).filter(Boolean)).size;

      return {
        totals: { totalVolume: totalVolume, totalUpload: totalUpload, totalDownload: totalDownload, totalRecords: totalRecords, uniqueDevices: devices.length, uniqueApps: apps.length, uniqueGroups: groupCount },
        devices: devices,
        apps: apps,
      };
    }

    function formatVolume(kb) {
      if (kb >= 1024 * 1024) return (kb / (1024 * 1024)).toFixed(2) + ' GB';
      if (kb >= 1024) return (kb / 1024).toFixed(2) + ' MB';
      return kb.toFixed(1) + ' KB';
    }

    function formatDate(d) {
      if (!d) return '—';
      return d.toISOString().slice(0, 10);
    }

    // ---- State ----
    var lastRows = [];
    var reportDateRange = { min: null, max: null };
    var filters = { dateFrom: null, dateTo: null, network: 'all', topN: 10, selectedPaths: [] };
    var topChart = null;
    var lastAgg = null;
    var currentTab = 'apps';

    function filterRows(rows) {
      return rows.filter(function (r) {
        if (filters.dateFrom && r.date && r.date < filters.dateFrom) return false;
        if (filters.dateTo && r.date && r.date > filters.dateTo) return false;
        if (filters.network !== 'all' && r.network !== filters.network) return false;
        if (filters.selectedPaths.length > 0) {
          var lookup = lookupFor(r.deviceName);
          var path = lookup ? lookup.path : '';
          if (filters.selectedPaths.indexOf(path) === -1) return false;
        }
        return true;
      });
    }

    function renderGroupFilterList(rows) {
      var paths = new Set();
      rows.forEach(function (r) {
        var lookup = lookupFor(r.deviceName);
        if (lookup && lookup.path) paths.add(lookup.path);
      });
      var list = document.getElementById('groupFilterList');
      var sorted = Array.from(paths).sort();
      if (sorted.length === 0) {
        list.innerHTML = '<p class="empty">No group data available for these devices.</p>';
        return;
      }
      list.innerHTML = sorted.map(function (p) {
        var esc = p.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;');
        return '<label class="filter-option"><input type="checkbox" value="' + esc + '" class="groupCheckbox"> <span>' + esc + '</span></label>';
      }).join('');
    }

    function esc(s) { return String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;'); }

    // Renders the active tab's (Top Applications / Top Users) chart + table
    // from the already-computed, already-sorted lastAgg. Cheap enough to
    // re-run on every tab click without touching filters or re-aggregating.
    function renderTopList() {
      if (!lastAgg) return;
      var isApps = currentTab === 'apps';
      var all = isApps ? lastAgg.apps : lastAgg.devices;
      var top = all.slice(0, filters.topN);

      document.getElementById('topListTitle').textContent = isApps ? 'Top applications by data used' : 'Top users by data used';
      document.getElementById('topListCount').textContent =
        top.length + ' shown · ' + all.length + ' ' + (isApps ? (all.length === 1 ? 'app' : 'apps') : (all.length === 1 ? 'user' : 'users'));

      var thead = document.getElementById('topListThead');
      var tbody = document.getElementById('topListBody');

      if (isApps) {
        thead.innerHTML = '<tr><th>#</th><th>Application</th><th>Upload</th><th>Download</th><th>Total</th></tr>';
        tbody.innerHTML = top.map(function (a, i) {
          return '<tr><td>' + (i + 1) + '</td><td>' + esc(a.name) + '</td><td>' + formatVolume(a.upload) +
            '</td><td>' + formatVolume(a.download) + '</td><td>' + formatVolume(a.volume) + '</td></tr>';
        }).join('') || '<tr><td colspan="5" class="empty">No applications match the current filter.</td></tr>';
      } else {
        thead.innerHTML = '<tr><th>#</th><th>User</th><th>Group Path</th><th>Upload</th><th>Download</th><th>Total</th></tr>';
        tbody.innerHTML = top.map(function (d, i) {
          var display = d.email || d.name;
          var tag = d.email ? '' : ' <span class="tag">unmapped</span>';
          return '<tr><td>' + (i + 1) + '</td><td>' + esc(display) + tag + '</td><td>' + esc(d.path) + '</td><td>' +
            formatVolume(d.upload) + '</td><td>' + formatVolume(d.download) + '</td><td>' + formatVolume(d.volume) + '</td></tr>';
        }).join('') || '<tr><td colspan="6" class="empty">No users match the current filter.</td></tr>';
      }

      var ctx = document.getElementById('topChart').getContext('2d');
      if (topChart) topChart.destroy();
      topChart = new Chart(ctx, {
        type: 'bar',
        data: {
          labels: top.map(function (x) { return isApps ? x.name : (x.email || x.name); }),
          datasets: [
            { label: 'Upload', data: top.map(function (x) { return x.upload; }), backgroundColor: '#4fd1e5' },
            { label: 'Download', data: top.map(function (x) { return x.download; }), backgroundColor: '#f5a623' },
          ],
        },
        options: {
          indexAxis: 'y',
          plugins: { legend: { display: true, labels: { color: '#e8eef7', boxWidth: 12 } } },
          scales: {
            x: { stacked: true, ticks: { color: '#8597b0' }, grid: { color: '#26334a' } },
            y: { stacked: true, ticks: { color: '#e8eef7' }, grid: { display: false } },
          },
        },
      });
    }

    function renderAll() {
      var filtered = filterRows(lastRows);
      var agg = aggregate(filtered);
      agg.devices = agg.devices.slice().sort(function (a, b) { return b.volume - a.volume; });
      agg.apps = agg.apps.slice().sort(function (a, b) { return b.volume - a.volume; });
      lastAgg = agg;

      document.getElementById('statVolume').textContent = formatVolume(agg.totals.totalVolume);
      document.getElementById('statApps').textContent = agg.totals.uniqueApps;
      document.getElementById('statDevices').textContent = agg.totals.uniqueDevices;
      document.getElementById('statGroups').textContent = agg.totals.uniqueGroups;
      document.getElementById('statDateRange').textContent =
        (filters.dateFrom ? formatDate(filters.dateFrom) : formatDate(reportDateRange.min)) + ' → ' +
        (filters.dateTo ? formatDate(filters.dateTo) : formatDate(reportDateRange.max));
      document.getElementById('statReportCreated').textContent = formatDate(reportDateRange.max);

      var networkLabel = filters.network === 'all' ? 'all networks' : filters.network === 'wifi' ? 'Wi-Fi only' : 'Cellular only';
      document.getElementById('filterPill').textContent =
        formatDate(filters.dateFrom || reportDateRange.min) + ' → ' + formatDate(filters.dateTo || reportDateRange.max) + ' · ' + networkLabel;

      renderTopList();
    }

    function loadReport(result) {
      lastRows = result.rows;
      reportDateRange = fullDateRange(lastRows);
      filters = { dateFrom: reportDateRange.min, dateTo: reportDateRange.max, network: 'all', topN: 10, selectedPaths: [] };

      var fromInput = document.getElementById('fromDate');
      var toInput = document.getElementById('toDate');
      fromInput.value = reportDateRange.min ? formatDate(reportDateRange.min) : '';
      toInput.value = reportDateRange.max ? formatDate(reportDateRange.max) : '';
      document.querySelectorAll('#networkSeg .seg-btn').forEach(function (b) { b.classList.toggle('active', b.dataset.network === 'all'); });
      document.getElementById('topNSelect').value = '10';

      renderGroupFilterList(lastRows);
      renderAll();
      document.getElementById('results').classList.remove('hidden');
    }

    // ---- File handling ----
    function showError(msg) {
      var el = document.getElementById('err');
      if (!msg) { el.classList.add('hidden'); el.textContent = ''; return; }
      el.textContent = msg;
      el.classList.remove('hidden');
    }

    function handleFile(file) {
      showError('');
      if (!file) return;
      Papa.parse(file, {
        skipEmptyLines: false,
        complete: function (results) {
          lookupReady.finally(function () {
            var parsed = parseReport(results.data);
            if (parsed.error) { showError(parsed.error); return; }
            if (parsed.rows.length === 0) {
              showError('No usage rows found in this file (0 records with a device name). Check it\'s the right export.');
              return;
            }
            loadReport(parsed);
          });
        },
        error: function (err) {
          showError('Could not read file: ' + err.message);
        },
      });
    }

    var dropZone = document.getElementById('dropZone');
    var fileInput = document.getElementById('fileInput');
    dropZone.addEventListener('click', function () { fileInput.click(); });
    fileInput.addEventListener('change', function (e) { handleFile(e.target.files[0]); });
    ['dragenter', 'dragover'].forEach(function (evt) {
      dropZone.addEventListener(evt, function (e) { e.preventDefault(); dropZone.classList.add('drag'); });
    });
    ['dragleave', 'drop'].forEach(function (evt) {
      dropZone.addEventListener(evt, function (e) { e.preventDefault(); dropZone.classList.remove('drag'); });
    });
    dropZone.addEventListener('drop', function (e) {
      var file = e.dataTransfer.files && e.dataTransfer.files[0];
      handleFile(file);
    });

    // ---- Top Applications / Top Users tab wiring ----
    document.querySelectorAll('.tab-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        document.querySelectorAll('.tab-btn').forEach(function (b) { b.classList.remove('active'); });
        btn.classList.add('active');
        currentTab = btn.dataset.tab;
        renderTopList();
      });
    });

    // ---- Filter bar wiring ----
    document.querySelectorAll('#networkSeg .seg-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        document.querySelectorAll('#networkSeg .seg-btn').forEach(function (b) { b.classList.remove('active'); });
        btn.classList.add('active');
      });
    });

    document.getElementById('applyMainFilterBtn').addEventListener('click', function () {
      var fromVal = document.getElementById('fromDate').value;
      var toVal = document.getElementById('toDate').value;
      filters.dateFrom = fromVal ? new Date(fromVal + 'T00:00:00') : null;
      filters.dateTo = toVal ? new Date(toVal + 'T23:59:59') : null;
      var activeSeg = document.querySelector('#networkSeg .seg-btn.active');
      filters.network = activeSeg ? activeSeg.dataset.network : 'all';
      filters.topN = parseInt(document.getElementById('topNSelect').value, 10) || 10;
      filters.selectedPaths = Array.from(document.querySelectorAll('.groupCheckbox:checked')).map(function (el) { return el.value; });
      if (lastRows.length > 0) renderAll();
    });

    document.getElementById('clearGroupsLink').addEventListener('click', function (e) {
      e.preventDefault();
      document.querySelectorAll('.groupCheckbox:checked').forEach(function (el) { el.checked = false; });
    });
  })();
  </script>
</body>
</html>
