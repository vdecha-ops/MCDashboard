<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Telecom Data Usage Dashboard</title>
<link rel="stylesheet" href="/style.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.4.1/papaparse.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
</head>
<body>
<div class="wrap">

  <header class="top">
    <div>
      <h1>Telecom Data Usage</h1>
      <div class="sub">Import a MobiControl usage export and explore consumption by app and device.</div>
    </div>
    <div style="display:flex;gap:16px;align-items:center;">
      <span class="signed-in">Signed in as <%= username %></span>
      <button type="button" class="ghost hidden" id="resetBtn">Import another file</button>
      <a href="/logout" class="back">Sign out</a>
    </div>
  </header>

  <!-- IMPORT -->
  <div id="importCard" class="card">
    <div class="drop" id="drop">
      <h2>Drop your CSV here</h2>
      <p>or click to browse — the file stays in your browser, nothing is uploaded.</p>
      <input type="file" id="file" accept=".csv,text/csv" class="hidden">
    </div>
    <div id="importErr" class="err hidden"></div>
    <div id="lookupStatus" class="hint"></div>
    <div class="hint">Expects columns: Device Name, Date &amp; Time, Volume (KB), Type, Application ID (the standard Telecom Data Usage export). Any junk title/summary rows above the real header are skipped automatically.</div>
  </div>

  <!-- DASHBOARD -->
  <div id="dash" class="hidden">

    <div class="card">
      <div class="stats" id="summary"></div>
    </div>

    <div class="card">
      <div class="controls">
        <div>
          <label>From</label>
          <input type="date" id="from">
        </div>
        <div>
          <label>To</label>
          <input type="date" id="to">
        </div>
        <div>
          <label>Network</label>
          <div class="seg" id="netSeg">
            <button type="button" data-net="all" class="on">All</button>
            <button type="button" data-net="wifi">Wi-Fi</button>
            <button type="button" data-net="cellular">Cellular</button>
          </div>
        </div>
        <div>
          <label>Show top</label>
          <select id="topN"><option>5</option><option selected>10</option><option>20</option><option value="999999">All</option></select>
        </div>
        <div>
          <label>Device groups</label>
          <div class="msel" id="grpSel">
            <button type="button" id="grpToggle" class="mselbtn">All groups</button>
            <div class="mselpop hidden" id="grpPop"></div>
          </div>
        </div>
      </div>
      <div style="margin-top:16px;display:flex;gap:10px;align-items:center;">
        <button type="button" class="primary" id="applyBtn">Apply</button>
        <span class="pill" id="activeFilter"></span>
      </div>
    </div>

    <div class="card" id="groupSummaryCard">
      <div class="panelhead"><h2>Per-group summary</h2><span class="pill" id="grpSumCount"></span></div>
      <div class="groupcards" id="groupCards"></div>
    </div>

    <div class="tabs" id="tabs">
      <button type="button" data-tab="apps" class="on">Top Apps</button>
      <button type="button" data-tab="devices">Top Devices</button>
    </div>

    <!-- ===== TOP APPS TAB ===== -->
    <div id="tab-apps">
      <div class="card" id="appsCard">
        <div class="panelhead">
          <h2>Top applications by data used</h2>
          <span class="pill" id="appCount"></span>
        </div>
        <canvas id="appChart" style="max-height:300px;"></canvas>
        <table id="appTable">
          <thead><tr>
            <th class="rank">#</th><th>Application</th>
            <th class="num bar-wifi">Upload</th><th class="num bar-cell">Download</th><th class="num">Total</th>
          </tr></thead>
          <tbody></tbody>
        </table>
        <div class="hint">Click an app row or bar to see which devices consumed it.</div>
      </div>

      <div class="card hidden" id="drillCard">
        <div class="panelhead">
          <h2>Devices using <span class="appname" id="drillApp"></span></h2>
          <a href="#" class="back" id="drillBack">← all apps</a>
        </div>
        <canvas id="drillChart" style="max-height:280px;"></canvas>
        <table id="drillTable">
          <thead><tr>
            <th class="rank">#</th><th>Device</th>
            <th class="num bar-wifi">Upload</th><th class="num bar-cell">Download</th><th class="num">Total</th>
          </tr></thead>
          <tbody></tbody>
        </table>
      </div>
    </div>

    <!-- ===== TOP DEVICES TAB ===== -->
    <div id="tab-devices" class="hidden">
      <div class="card" id="devicesCard">
        <div class="panelhead">
          <h2>Top devices by data used</h2>
          <span class="pill" id="devCount"></span>
        </div>
        <canvas id="devChart" style="max-height:300px;"></canvas>
        <table id="devTable">
          <thead><tr>
            <th class="rank">#</th><th>Device</th>
            <th class="num bar-wifi">Upload</th><th class="num bar-cell">Download</th><th class="num">Total</th>
          </tr></thead>
          <tbody></tbody>
        </table>
        <div class="hint">Click a device row or bar to see which apps it consumed.</div>
      </div>

      <div class="card hidden" id="devDrillCard">
        <div class="panelhead">
          <h2>Apps used by <span class="appname" id="devDrillName"></span></h2>
          <a href="#" class="back" id="devDrillBack">← all devices</a>
        </div>
        <canvas id="devDrillChart" style="max-height:300px;"></canvas>
        <table id="devDrillTable">
          <thead><tr>
            <th class="rank">#</th><th>Application</th>
            <th class="num bar-wifi">Upload</th><th class="num bar-cell">Download</th><th class="num">Total</th>
          </tr></thead>
          <tbody></tbody>
        </table>
      </div>
    </div>

  </div>
</div>

<script>
const $ = id => document.getElementById(id);
let ROWS = [];          // normalized records
let REPORT_CREATED = '—';

// ---- Device lookup (email + group path per device name), fetched once from
// this app's own MobiControl session -- replaces the template's hardcoded
// DEVICE_MAP with live data. ----
let deviceLookup = {};
let lookupReady = fetch('/api/device-lookup')
  .then(r => { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
  .then(data => {
    (data.devices || []).forEach(d => { if (d && d.name) deviceLookup[d.name.trim().toLowerCase()] = d; });
    $('lookupStatus').textContent = Object.keys(deviceLookup).length + ' device(s) loaded from MobiControl for email/group matching.';
  })
  .catch(err => { $('lookupStatus').textContent = 'Could not load device list from MobiControl (' + err.message + '). Devices will show without email/group.'; });

function lookupFor(deviceName) { return deviceLookup[String(deviceName || '').trim().toLowerCase()] || null; }
function deviceLabel(deviceName) {
  const lookup = lookupFor(deviceName);
  return (lookup && lookup.email) ? lookup.email : deviceName;
}
function deviceGroup(deviceName) {
  const lookup = lookupFor(deviceName);
  if (lookup && lookup.path) return lookup.path;
  return deviceName.includes(':') ? deviceName.split(':')[0].trim() : '(ungrouped)';
}

// Display-only: strip the common organization root off a MobiControl group
// path so lists show just the meaningful subgroup name. Filtering still
// matches on the full untrimmed path -- only the label shown to the user
// is shortened.
const GROUP_PREFIX_TO_TRIM = '\\\\My Company\\1.Production\\1.1 Device Group\\';
function trimGroupName(g) {
  return g.startsWith(GROUP_PREFIX_TO_TRIM) ? g.slice(GROUP_PREFIX_TO_TRIM.length) : g;
}

let netFilter = 'all';
let selectedGroups = null;   // null = all groups
let selectedApp = null;
let appChart=null, drillChart=null;
let devChart=null, devDrillChart=null;
let currentTab='apps';
let lastRows=[];   // rows from the most recent apply(), shared by both tabs

// ---------- formatting ----------
const fmt = kb => {
  if (kb >= 1048576) return (kb/1048576).toFixed(2)+' GB';
  if (kb >= 1024)    return (kb/1024).toFixed(1)+' MB';
  return kb.toFixed(0)+' KB';
};

// ---------- import ----------
const drop = $('drop'), fileInput = $('file');
drop.onclick = () => fileInput.click();
['dragover','dragenter'].forEach(e=>drop.addEventListener(e,ev=>{ev.preventDefault();drop.classList.add('drag');}));
['dragleave','drop'].forEach(e=>drop.addEventListener(e,ev=>{ev.preventDefault();drop.classList.remove('drag');}));
drop.addEventListener('drop', ev => { if(ev.dataTransfer.files.length) handleFile(ev.dataTransfer.files[0]); });
fileInput.onchange = () => { if(fileInput.files.length) handleFile(fileInput.files[0]); };
$('resetBtn').onclick = () => location.reload();

function handleFile(file){
  const err = $('importErr'); err.classList.add('hidden'); err.textContent = '';
  Papa.parse(file, {
    skipEmptyLines: false,
    complete: res => {
      lookupReady.finally(() => {
        try { ingest(res.data); }
        catch(e){ err.textContent = e.message; err.classList.remove('hidden'); }
      });
    },
    error: e => { err.textContent = 'Could not read file: '+e.message; err.classList.remove('hidden'); }
  });
}

function num(v){ const n = parseFloat(String(v==null?'':v).replace(/,/g,'').trim()); return isFinite(n)?n:0; }
function normCell(c){ return String(c==null?'':c).trim(); }

// MobiControl's export has a few junk title/summary rows above the real
// header, and the header's own column positions shift depending on merged
// cells in the source spreadsheet -- so the header row is found by content
// (a row containing both "Device Name" and "Volume"), not a fixed index.
function findHeaderRow(rows){
  for (let i=0;i<Math.min(rows.length,25);i++){
    const row=rows[i]; let hasDevice=false, hasVolume=false;
    for (let j=0;j<row.length;j++){
      const c=normCell(row[j]).toLowerCase();
      if (/device\s*name/.test(c)) hasDevice=true;
      if (/volume/.test(c)) hasVolume=true;
    }
    if (hasDevice && hasVolume) return i;
  }
  return -1;
}
function mapColumns(headerRow){
  const cols={};
  headerRow.forEach((cell,idx)=>{
    const c=normCell(cell).toLowerCase();
    if (cols.dateTime===undefined && /date/.test(c)) cols.dateTime=idx;
    else if (cols.device===undefined && /device\s*name/.test(c)) cols.device=idx;
    else if (cols.upload===undefined && /upload/.test(c)) cols.upload=idx;
    else if (cols.download===undefined && /download/.test(c)) cols.download=idx;
    else if (cols.volume===undefined && /volume/.test(c)) cols.volume=idx;
    else if (cols.type===undefined && /^type$/.test(c)) cols.type=idx;
    else if (cols.app===undefined && /applic/.test(c)) cols.app=idx;
  });
  return cols;
}
function parseDate(v){
  const s=normCell(v); if(!s) return null;
  const d=new Date(s); return isNaN(d.getTime())?null:d;
}
function isWifi(t){ return /wi-?fi/i.test(t||''); }
function isCell(t){ return /cell|mobile|data|3g|4g|5g|lte/i.test(t||''); }

function ingest(data){
  if(!data.length) throw new Error('The file has no rows.');
  const headerIdx = findHeaderRow(data);
  if (headerIdx===-1) throw new Error('Could not find a header row with "Device Name" and "Volume" columns.');
  const cols = mapColumns(data[headerIdx]);
  if (cols.device===undefined || cols.volume===undefined) {
    throw new Error('Missing expected column(s): device name, volume (kb).');
  }

  ROWS = [];
  let maxDate = null;
  for (let i=headerIdx+1;i<data.length;i++){
    const row = data[i];
    if (!row || row.length===0) continue;
    const device = normCell(row[cols.device]);
    if (!device) continue;
    const date = cols.dateTime!==undefined ? parseDate(row[cols.dateTime]) : null;
    if (date && (!maxDate || date>maxDate)) maxDate = date;
    ROWS.push({
      device,
      date,
      vol: num(row[cols.volume]),
      up: cols.upload!==undefined ? num(row[cols.upload]) : 0,
      down: cols.download!==undefined ? num(row[cols.download]) : 0,
      type: cols.type!==undefined ? normCell(row[cols.type]) : '',
      app: cols.app!==undefined ? (normCell(row[cols.app]) || '(unknown)') : '(unknown)',
    });
  }
  ROWS = ROWS.filter(r => r.date);
  if(!ROWS.length) throw new Error('No usage rows with a valid date were found. Check this is the right export.');
  REPORT_CREATED = maxDate ? maxDate.toISOString().slice(0,10) : '—';

  buildControls();
  $('importCard').classList.add('hidden');
  $('resetBtn').classList.remove('hidden');
  $('dash').classList.remove('hidden');
  apply();
}

// ---------- controls ----------
function buildControls(){
  const dates = ROWS.map(r=>r.date);
  const min = new Date(Math.min(...dates)), max = new Date(Math.max(...dates));
  const iso = d => d.toISOString().slice(0,10);
  $('from').value = iso(min); $('from').min = iso(min); $('from').max = iso(max);
  $('to').value   = iso(max); $('to').min   = iso(min); $('to').max   = iso(max);

  const groups = [...new Set(ROWS.map(r=>deviceGroup(r.device)))].sort();
  buildGroupSelect(groups);

  const totalKb = ROWS.reduce((s,r)=>s+r.vol,0);
  $('summary').innerHTML = `
    <div class="stat"><div class="n">${fmt(totalKb)}</div><div class="l">total volume</div></div>
    <div class="stat"><div class="n">${new Set(ROWS.map(r=>r.app)).size}</div><div class="l">apps</div></div>
    <div class="stat"><div class="n">${new Set(ROWS.map(r=>r.device)).size}</div><div class="l">devices</div></div>
    <div class="stat"><div class="n">${groups.length}</div><div class="l">groups</div></div>
    <div class="stat"><div class="n">${iso(min)} → ${iso(max)}</div><div class="l">date range</div></div>
    <div class="stat"><div class="n">${REPORT_CREATED}</div><div class="l">report created</div></div>`;
}

$('netSeg').querySelectorAll('button').forEach(b=>{
  b.onclick=()=>{ $('netSeg').querySelectorAll('button').forEach(x=>x.classList.remove('on'));
    b.classList.add('on'); netFilter=b.dataset.net; };
});

// ---------- group multi-select ----------
function buildGroupSelect(groups){
  selectedGroups = new Set(groups);   // default: all selected
  const pop = $('grpPop');
  pop.innerHTML =
    `<div class="msel-actions"><a id="grpAll">Select all</a><a id="grpNone">Clear</a></div>` +
    groups.map(g=>`<label><input type="checkbox" class="grpChk" value="${g.replace(/"/g,'&quot;')}" checked> ${esc(trimGroupName(g))}</label>`).join('');
  pop.querySelectorAll('.grpChk').forEach(c=>{
    c.onchange=()=>{ c.checked ? selectedGroups.add(c.value) : selectedGroups.delete(c.value); updateGrpLabel(groups); };
  });
  pop.querySelector('#grpAll').onclick=()=>{ pop.querySelectorAll('.grpChk').forEach(c=>{c.checked=true;selectedGroups.add(c.value);}); updateGrpLabel(groups); };
  pop.querySelector('#grpNone').onclick=()=>{ pop.querySelectorAll('.grpChk').forEach(c=>{c.checked=false;}); selectedGroups.clear(); updateGrpLabel(groups); };
  updateGrpLabel(groups);
}
function updateGrpLabel(groups){
  const n=selectedGroups.size, tot=groups.length;
  $('grpToggle').textContent = (n===0)?'No groups' : (n===tot)?'All groups' : `${n} of ${tot} groups`;
}
$('grpToggle').onclick=(e)=>{ e.stopPropagation(); $('grpPop').classList.toggle('hidden'); };
document.addEventListener('click',(e)=>{ if(!$('grpSel').contains(e.target)) $('grpPop').classList.add('hidden'); });

$('applyBtn').onclick = apply;
$('drillBack').onclick = (e) => { e.preventDefault(); selectedApp=null; $('drillCard').classList.add('hidden');
  document.querySelectorAll('#appTable tr.sel').forEach(t=>t.classList.remove('sel')); };
$('devDrillBack').onclick=(e)=>{ e.preventDefault(); $('devDrillCard').classList.add('hidden');
  document.querySelectorAll('#devTable tr.sel').forEach(t=>t.classList.remove('sel')); };

// ---------- filtering ----------
function activeRows(){
  const from = new Date($('from').value+'T00:00:00');
  const to   = new Date($('to').value+'T23:59:59');
  const grpOn = selectedGroups && selectedGroups.size>0;
  return ROWS.filter(r =>
    r.date>=from && r.date<=to &&
    (netFilter==='all' || (netFilter==='wifi'?isWifi(r.type):isCell(r.type))) &&
    (!grpOn || selectedGroups.has(deviceGroup(r.device)))
  );
}

function apply(){
  selectedApp=null; $('drillCard').classList.add('hidden');
  $('devDrillCard').classList.add('hidden');
  const rows = activeRows();
  lastRows = rows;
  const n = +$('topN').value;

  const byApp = {};
  rows.forEach(r=>{
    const a = byApp[r.app] || (byApp[r.app]={up:0,down:0,total:0});
    a.up+=r.up; a.down+=r.down; a.total+=r.vol;
  });
  const apps = Object.entries(byApp).map(([app,v])=>({app,...v}))
    .sort((x,y)=>y.total-x.total).slice(0,n);

  const byDev = {};
  rows.forEach(r=>{
    const d = byDev[r.device] || (byDev[r.device]={up:0,down:0,total:0});
    d.up+=r.up; d.down+=r.down; d.total+=r.vol;
  });
  const devices = Object.entries(byDev).map(([device,v])=>({device,...v}))
    .sort((x,y)=>y.total-x.total).slice(0,n);

  const grpTxt = (selectedGroups && $('grpToggle')) ? ' · '+$('grpToggle').textContent.toLowerCase() : '';
  $('activeFilter').textContent =
    `${$('from').value} → ${$('to').value} · ${netFilter==='all'?'all networks':netFilter}${grpTxt}`;
  $('appCount').textContent = `${apps.length} shown · ${rows.length.toLocaleString()} records`;
  $('devCount').textContent = `${devices.length} shown · ${rows.length.toLocaleString()} records`;

  renderAppTable(apps);
  renderAppChart(apps);
  renderDevTable(devices);
  renderDevChart(devices);
  renderGroupCards(rows);

  // Best-effort live Play Store names; re-render if any resolve.
  enrichNames(apps.map(a=>a.app)).then(changed=>{
    if(!changed) return;
    renderAppTable(apps);
    renderAppChart(apps);
    renderGroupCards(rows);
  });
}

function esc(s){ return String(s==null?'':s).replace(/&/g,'&amp;').replace(/</g,'&lt;'); }

// ---------- package name -> friendly app name ----------
// Curated fallback for common packages so a name shows instantly without
// waiting on (or needing) a network round-trip.
const APP_NAMES = {
  'com.ais.mimo.eservice':'myAIS',
  'com.android.chrome':'Chrome',
  'com.android.intentresolver':'Android System (Intent Resolver)',
  'com.android.providers.downloads.ui':'Download Manager',
  'com.android.vending':'Google Play Store',
  'com.aura.oobe.samsung.gl':'Samsung Setup (Aura)',
  'com.azure.authenticator':'Microsoft Authenticator',
  'com.google.android.apps.maps':'Google Maps',
  'com.google.android.apps.messaging':'Google Messages',
  'com.google.android.apps.photos':'Google Photos',
  'com.google.android.apps.tachyon':'Google Meet',
  'com.google.android.apps.work.clouddpc':'Android Device Policy',
  'com.google.android.as':'Android System Intelligence',
  'com.google.android.configupdater':'Google Config Updater',
  'com.google.android.ext.services':'Android Services',
  'com.google.android.gm':'Gmail',
  'com.google.android.gms':'Google Play Services',
  'com.google.android.gms.location.history':'Google Location History',
  'com.google.android.googlequicksearchbox':'Google',
  'com.google.android.syncadapters.calendar':'Google Calendar Sync',
  'com.google.android.tts':'Google Text-to-Speech',
  'com.google.android.webview':'Android System WebView',
  'com.google.android.youtube':'YouTube',
  'com.google.ar.core':'Google Play Services for AR',
  'com.hiya.star':'Hiya (Caller ID)',
  'com.jeyluta.timestampcamerafree':'Timestamp Camera Free',
  'com.microsoft.msapps':'Microsoft Apps',
  'com.microsoft.office.officehubrow':'Microsoft 365 (Office)',
  'com.microsoft.office.outlook':'Microsoft Outlook',
  'com.microsoft.skydrive':'Microsoft OneDrive',
  'com.microsoft.teams':'Microsoft Teams',
  'com.osp.app.signin':'Samsung Account',
  'com.samsung.android.app.contacts':'Samsung Contacts',
  'com.samsung.android.app.sharelive':'Samsung Quick Share',
  'com.samsung.android.app.smartcapture':'Samsung Smart Capture',
  'com.samsung.android.calendar':'Samsung Calendar',
  'com.samsung.android.game.gametools':'Samsung Game Tools',
  'com.samsung.android.honeyboard':'Samsung Keyboard',
  'com.samsung.android.kgclient':'Samsung Knox Guard',
  'com.samsung.android.mdx.kit':'Samsung Continuity',
  'com.samsung.android.samsungpass':'Samsung Pass',
  'com.samsung.android.scloud':'Samsung Cloud',
  'com.samsung.android.simagent':'Samsung SIM Agent',
  'com.samsung.android.smartsuggestions':'Samsung Smart Suggestions',
  'com.sec.android.app.SecSetupWizard':'Samsung Setup Wizard',
  'com.sec.android.app.billing':'Samsung Billing',
  'com.sec.android.app.camera':'Samsung Camera',
  'com.sec.android.app.samsungapps':'Galaxy Store',
  'com.sec.android.daemonapp':'Samsung Weather',
  'com.sec.android.gallery3d':'Samsung Gallery',
  'com.touchtype.swiftkey':'Microsoft SwiftKey',
  'com.whatsapp':'WhatsApp',
  'net.soti.mobicontrol.androidwork':'SOTI MobiControl',
  'net.soti.xsight':'SOTI XSight',
  '(unknown)':'(unknown)',
};
// Live Play Store lookups cached here (best-effort; often blocked by CORS
// when fetched from the browser, in which case the fallback name is kept).
const APP_NAME_CACHE = {};
function appName(pkg){
  if(APP_NAMES[pkg]) return APP_NAMES[pkg];
  if(APP_NAME_CACHE[pkg]) return APP_NAME_CACHE[pkg];
  const generic = new Set(['android','app','apps','client','service','services','mobile','main']);
  const parts = String(pkg).split('.').filter(Boolean);
  let seg = parts[parts.length-1] || pkg;
  if(generic.has(seg.toLowerCase()) && parts.length>1) seg = parts[parts.length-2];
  return seg.replace(/[_-]/g,' ').replace(/\b\w/g,c=>c.toUpperCase());
}
// Best-effort: try to resolve real names from the Play Store listing title
// at runtime for packages not already in APP_NAMES. Silently keeps the
// derived fallback name if the request fails or is blocked by CORS.
async function enrichNames(pkgs){
  const todo = pkgs.filter(p=>p && p!=='(unknown)' && !APP_NAMES[p] && !APP_NAME_CACHE[p]);
  if(!todo.length) return false;
  const results = await Promise.all(todo.map(async p=>{
    try{
      const url='https://play.google.com/store/apps/details?id='+encodeURIComponent(p)+'&hl=en';
      const res=await fetch(url);
      if(!res.ok) return false;
      const html=await res.text();
      const m=html.match(/<title[^>]*>([^<]+?)(?:\s*[-–]\s*Apps on Google Play)?<\/title>/i);
      if(m&&m[1]&&!/Google Play/i.test(m[1])){ APP_NAME_CACHE[p]=m[1].trim(); return true; }
      return false;
    }catch(e){ return false; /* CORS or offline: keep fallback name */ }
  }));
  return results.some(Boolean);
}

// ---------- top apps tab ----------
function renderAppTable(apps){
  const tb=$('appTable').querySelector('tbody'); tb.innerHTML='';
  if (!apps.length) { tb.innerHTML = '<tr><td colspan="5" class="empty">No applications match the current filter.</td></tr>'; return; }
  apps.forEach((a,i)=>{
    const tr=document.createElement('tr'); tr.className='click';
    tr.innerHTML=`<td class="rank">${i+1}</td><td><span class="appname">${esc(appName(a.app))}</span><div class="muted" style="font-size:11px;">${esc(a.app)}</div></td>
      <td class="num bar-wifi">${fmt(a.up)}</td>
      <td class="num bar-cell">${fmt(a.down)}</td>
      <td class="num">${fmt(a.total)}</td>`;
    tr.onclick=()=>{ drillApp(a.app);
      document.querySelectorAll('#appTable tr.sel').forEach(t=>t.classList.remove('sel'));
      tr.classList.add('sel'); };
    tb.appendChild(tr);
  });
}

function renderAppChart(apps){
  if(appChart) appChart.destroy();
  appChart=new Chart($('appChart'),{
    type:'bar',
    data:{labels:apps.map(a=>appName(a.app)),datasets:[
      {label:'Upload',data:apps.map(a=>a.up/1048576),backgroundColor:'#4cc3ff'},
      {label:'Download',data:apps.map(a=>a.down/1048576),backgroundColor:'#ffb648'}]},
    options:{responsive:true,
      plugins:{legend:{labels:{color:'#8597b0'}},tooltip:{callbacks:{
        label:c=>`${c.dataset.label}: ${c.parsed.y.toFixed(2)} GB`}}},
      scales:{x:{stacked:true,ticks:{color:'#8597b0',maxRotation:60,minRotation:30},grid:{color:'#1c2840'}},
              y:{stacked:true,ticks:{color:'#8597b0'},grid:{color:'#1c2840'},title:{display:true,text:'GB',color:'#5d6f8a'}}},
      onClick:(e,el)=>{ if(el.length) drillApp(apps[el[0].index].app); }}
  });
}

// ---------- top devices tab ----------
function shortDev(d){ const p=d.split(/[:\-]/); return p[p.length-1].trim() || d; }

function renderDevTable(devices){
  const tb=$('devTable').querySelector('tbody'); tb.innerHTML='';
  if (!devices.length) { tb.innerHTML = '<tr><td colspan="5" class="empty">No devices match the current filter.</td></tr>'; return; }
  devices.forEach((d,i)=>{
    const label = deviceLabel(d.device);
    const sub = label !== d.device ? `<div class="muted" style="font-size:11px;">${esc(d.device)}</div>` : '';
    const tag = lookupFor(d.device) && lookupFor(d.device).email ? '' : ' <span class="tag">unmapped</span>';
    const tr=document.createElement('tr'); tr.className='click';
    tr.innerHTML=`<td class="rank">${i+1}</td><td>${esc(label)}${tag}${sub}</td>
      <td class="num bar-wifi">${fmt(d.up)}</td>
      <td class="num bar-cell">${fmt(d.down)}</td>
      <td class="num">${fmt(d.total)}</td>`;
    tr.onclick=()=>{ drillDevice(d.device);
      document.querySelectorAll('#devTable tr.sel').forEach(t=>t.classList.remove('sel'));
      tr.classList.add('sel'); };
    tb.appendChild(tr);
  });
}

function renderDevChart(devices){
  if(devChart) devChart.destroy();
  devChart=new Chart($('devChart'),{
    type:'bar',
    data:{labels:devices.map(d=>shortDev(deviceLabel(d.device))),datasets:[
      {label:'Upload',data:devices.map(d=>d.up/1048576),backgroundColor:'#4cc3ff'},
      {label:'Download',data:devices.map(d=>d.down/1048576),backgroundColor:'#ffb648'}]},
    options:{responsive:true,
      plugins:{legend:{labels:{color:'#8597b0'}},tooltip:{callbacks:{
        label:c=>`${c.dataset.label}: ${c.parsed.y.toFixed(2)} GB`}}},
      scales:{x:{stacked:true,ticks:{color:'#8597b0',maxRotation:60,minRotation:30},grid:{color:'#1c2840'}},
              y:{stacked:true,ticks:{color:'#8597b0'},grid:{color:'#1c2840'},title:{display:true,text:'GB',color:'#5d6f8a'}}},
      onClick:(e,el)=>{ if(el.length) drillDevice(devices[el[0].index].device); }}
  });
}

// drill: apps used by a device
function drillDevice(device){
  const rows = activeRows().filter(r=>r.device===device);
  const byApp={};
  rows.forEach(r=>{
    const a=byApp[r.app]||(byApp[r.app]={up:0,down:0,total:0});
    a.up+=r.up; a.down+=r.down; a.total+=r.vol;
  });
  const apps=Object.entries(byApp).map(([app,v])=>({app,...v})).sort((x,y)=>y.total-x.total);

  $('devDrillName').textContent = deviceLabel(device);
  const tb=$('devDrillTable').querySelector('tbody'); tb.innerHTML='';
  apps.forEach((a,i)=>{
    const tr=document.createElement('tr');
    tr.innerHTML=`<td class="rank">${i+1}</td><td><span class="appname">${esc(appName(a.app))}</span><div class="muted" style="font-size:11px;">${esc(a.app)}</div></td>
      <td class="num bar-wifi">${fmt(a.up)}</td>
      <td class="num bar-cell">${fmt(a.down)}</td>
      <td class="num">${fmt(a.total)}</td>`;
    tb.appendChild(tr);
  });

  if(devDrillChart) devDrillChart.destroy();
  const top=apps.slice(0,15);
  devDrillChart=new Chart($('devDrillChart'),{
    type:'bar',
    data:{labels:top.map(a=>appName(a.app)),datasets:[
      {label:'Upload',data:top.map(a=>a.up/1048576),backgroundColor:'#4cc3ff'},
      {label:'Download',data:top.map(a=>a.down/1048576),backgroundColor:'#ffb648'}]},
    options:{responsive:true,indexAxis:'y',
      plugins:{legend:{labels:{color:'#8597b0'}},tooltip:{callbacks:{
        label:c=>`${c.dataset.label}: ${c.parsed.x.toFixed(2)} GB`}}},
      scales:{x:{stacked:true,ticks:{color:'#8597b0'},grid:{color:'#1c2840'},title:{display:true,text:'GB',color:'#5d6f8a'}},
              y:{stacked:true,ticks:{color:'#8597b0',font:{size:10}},grid:{color:'#1c2840'}}}}
  });

  $('devDrillCard').classList.remove('hidden');
  $('devDrillCard').scrollIntoView({behavior:'smooth',block:'start'});

  enrichNames(apps.map(a=>a.app)).then(changed=>{
    if(!changed) return;
    document.querySelectorAll('#devDrillTable .appname').forEach((el,i)=>{ if(apps[i]) el.textContent=appName(apps[i].app); });
    devDrillChart.data.labels = top.map(a=>appName(a.app));
    devDrillChart.update();
  });
}

// ---------- per-group summary cards ----------
function renderGroupCards(rows){
  const byGrp={};
  rows.forEach(r=>{
    const grp = deviceGroup(r.device);
    const g=byGrp[grp]||(byGrp[grp]={total:0,up:0,down:0,devs:new Set(),apps:{}});
    g.total+=r.vol; g.up+=r.up; g.down+=r.down; g.devs.add(r.device);
    g.apps[r.app]=(g.apps[r.app]||0)+r.vol;
  });
  const groups=Object.entries(byGrp).map(([group,v])=>({group,...v})).sort((a,b)=>b.total-a.total);
  $('grpSumCount').textContent=`${groups.length} group(s)`;
  const wrap=$('groupCards'); wrap.innerHTML='';
  if(!groups.length){ wrap.innerHTML='<div class="muted">No groups in current selection.</div>'; return; }
  groups.forEach(g=>{
    const topApp=Object.entries(g.apps).sort((a,b)=>b[1]-a[1])[0];
    const card=document.createElement('div'); card.className='gcard';
    card.innerHTML=`<h3 title="${esc(g.group)}">${esc(trimGroupName(g.group))}</h3>
      <div class="gtot">${fmt(g.total)}</div>
      <div class="grow"><span>${g.devs.size} device(s)</span><span>↑${fmt(g.up)} ↓${fmt(g.down)}</span></div>
      <div class="grow"><span>Top app</span><span title="${topApp?esc(topApp[0]):''}">${topApp?esc(appName(topApp[0])):'—'}</span></div>`;
    wrap.appendChild(card);
  });
}

// ---------- tab switching ----------
$('tabs').querySelectorAll('button').forEach(b=>{
  b.onclick=()=>{
    $('tabs').querySelectorAll('button').forEach(x=>x.classList.remove('on'));
    b.classList.add('on');
    currentTab=b.dataset.tab;
    $('tab-apps').classList.toggle('hidden', currentTab!=='apps');
    $('tab-devices').classList.toggle('hidden', currentTab!=='devices');
  };
});

// ---------- drilldown: devices using an app ----------
function drillApp(app){
  selectedApp=app;
  const rows = activeRows().filter(r=>r.app===app);
  const byDev={};
  rows.forEach(r=>{
    const d=byDev[r.device]||(byDev[r.device]={up:0,down:0,total:0});
    d.up+=r.up; d.down+=r.down; d.total+=r.vol;
  });
  const devs=Object.entries(byDev).map(([device,v])=>({device,...v})).sort((a,b)=>b.total-a.total);

  $('drillApp').textContent=appName(app);
  $('drillApp').title=app;
  const tb=$('drillTable').querySelector('tbody'); tb.innerHTML='';
  devs.forEach((d,i)=>{
    const label = deviceLabel(d.device);
    const sub = label !== d.device ? `<div class="muted" style="font-size:11px;">${esc(d.device)}</div>` : '';
    const tr=document.createElement('tr');
    tr.innerHTML=`<td class="rank">${i+1}</td><td>${esc(label)}${sub}</td>
      <td class="num bar-wifi">${fmt(d.up)}</td>
      <td class="num bar-cell">${fmt(d.down)}</td>
      <td class="num">${fmt(d.total)}</td>`;
    tb.appendChild(tr);
  });

  if(drillChart) drillChart.destroy();
  const top=devs.slice(0,15);
  drillChart=new Chart($('drillChart'),{
    type:'bar',
    data:{labels:top.map(d=>shortDev(deviceLabel(d.device))),datasets:[
      {label:'Upload',data:top.map(d=>d.up/1048576),backgroundColor:'#4cc3ff'},
      {label:'Download',data:top.map(d=>d.down/1048576),backgroundColor:'#ffb648'}]},
    options:{responsive:true,indexAxis:'y',
      plugins:{legend:{labels:{color:'#8597b0'}},tooltip:{callbacks:{
        label:c=>`${c.dataset.label}: ${c.parsed.x.toFixed(2)} GB`}}},
      scales:{x:{stacked:true,ticks:{color:'#8597b0'},grid:{color:'#1c2840'},title:{display:true,text:'GB',color:'#5d6f8a'}},
              y:{stacked:true,ticks:{color:'#8597b0',font:{size:10}},grid:{color:'#1c2840'}}}}
  });

  $('drillCard').classList.remove('hidden');
  $('drillCard').scrollIntoView({behavior:'smooth',block:'start'});

  enrichNames([app]).then(changed=>{ if(changed) $('drillApp').textContent=appName(app); });
}
</script>
</body>
</html>
