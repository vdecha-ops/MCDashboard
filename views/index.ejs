<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Telecom Data Usage Dashboard</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="wrap" style="max-width:460px;">
    <header class="top">
      <div>
        <h1>Telecom Data Usage</h1>
        <div class="sub">Server: <%= serverUrl %></div>
      </div>
    </header>

    <div class="card">
      <% if (error) { %>
        <div class="err"><%= error %></div>
      <% } %>

      <form method="post" action="/login">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" autocomplete="username" required>

        <label for="password">Password</label>
        <input type="password" id="password" name="password" autocomplete="current-password" required>

        <button type="submit" class="primary" style="width:100%;margin-top:20px;">Sign in</button>
      </form>

      <p class="hint">
        Sign in with your MobiControl administrator username and password.
        The API client (Client ID / Secret) is preconfigured on the server.
        After signing in you can upload a Telecom Data Usage report to explore.
      </p>
    </div>
  </div>
</body>
</html>
